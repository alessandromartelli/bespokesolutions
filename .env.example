# Copy this file to .env and fill in values. Never commit .env.
#
# All keys are stored in 1Password under "Bespoke Solutions / Stack".
# Ask a teammate for access if you don't have it.

# ══════════════════════════════════════════════════════
# Models
# ══════════════════════════════════════════════════════
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ══════════════════════════════════════════════════════
# Agent stack
# ══════════════════════════════════════════════════════

# Hermes Agent — the harness running on your VPS (or local)
HERMES_API_KEY=
# Set if Hermes runs on a remote VPS. Leave blank to use local `hermes mcp serve`.
HERMES_MCP_URL=

# Orgo — cloud computers per customer (defer until first paying customer)
ORGO_API_KEY=

# Agent Mail — email identity per agent
AGENTMAIL_API_KEY=

# ══════════════════════════════════════════════════════
# Composio — tool connector (1000+ apps via MCP)
# ══════════════════════════════════════════════════════
COMPOSIO_API_KEY=

# OPTION 1 (preferred): Unified Composio tool-router URL.
# Exposes every app you've connected in the Composio dashboard via one MCP.
COMPOSIO_TOOL_ROUTER_URL=

# OPTION 2: Per-app URLs (use these only if you don't have a tool-router URL).
# Grab each one from the Composio dashboard after connecting the app.
COMPOSIO_GMAIL_URL=
COMPOSIO_CALENDAR_URL=
COMPOSIO_LINKEDIN_URL=
COMPOSIO_SLACK_URL=
COMPOSIO_NOTION_URL=

# ══════════════════════════════════════════════════════
# France Travail (ex Pôle Emploi) — job postings API
# ══════════════════════════════════════════════════════
# Register free at https://francetravail.io/data/api/offres-emploi
# Scope needed: api_offresdemploiv2 o2dsoffre
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=

# ══════════════════════════════════════════════════════
# Research / tooling (optional — add when needed)
# ══════════════════════════════════════════════════════
PERPLEXITY_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=

# ══════════════════════════════════════════════════════
# GitHub
# ══════════════════════════════════════════════════════
# Personal access token. Needed for the github MCP server.
# Scope: repo, read:org
GITHUB_TOKEN=

# ══════════════════════════════════════════════════════
# Optional / future
# ══════════════════════════════════════════════════════
NOTION_API_KEY=
SLACK_BOT_TOKEN=

# App (if building web frontends later)
NODE_ENV=development
